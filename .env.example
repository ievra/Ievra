# Database Connection
DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# PostgreSQL Individual Credentials (optional - can use DATABASE_URL instead)
PGHOST=hostname
PGPORT=5432
PGUSER=username
PGPASSWORD=password
PGDATABASE=database_name

# Session Secret (for authentication - use a long random string)
SESSION_SECRET=your-secret-key-here

# Server Port (optional, defaults to 5000)
PORT=5000

# Node Environment
NODE_ENV=development

# Replit-managed (auto-injected in Replit environment, not needed locally)
# REPLIT_DEV_DOMAIN=your-repl.replit.dev
# REPLIT_DEPLOYMENT_URL=https://your-repl.replit.app
# REPL_ID=your-repl-id
